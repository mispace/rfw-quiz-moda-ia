# ============================================
# RFW 2026 Quiz Moda IA — Referência de variáveis
# ============================================
# Este arquivo é apenas referência. Nada aqui é lido pelo código.
# Cada valor deve ser colado no local indicado.

# -----------------------------------------------
# 1. ANTHROPIC_API_KEY
#    Onde colar: Google Apps Script (variável no topo do código)
#    Como obter: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# -----------------------------------------------
# 2. SHEET_ID
#    Onde colar: Google Apps Script (variável no topo do código)
#    Como obter: URL da planilha → entre /d/ e /edit
SHEET_ID=1abc2def3ghi4jkl

# -----------------------------------------------
# 3. BACKEND URL
#    Onde colar: config.js do frontend (campo backendUrl)
#    Como obter: Apps Script → Implantar → Nova implantação → copiar URL
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/xxx/exec
